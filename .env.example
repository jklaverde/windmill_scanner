# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite — fully self-contained, no external service required.
# All data is stored inside the mounted volume (/app/data).
#
# To use PostgreSQL instead, uncomment the line below and set your credentials:
# DATABASE_URL=postgresql://windmill_role:W1ndm1ll_sc4nn3r_@localhost:5432/windmill_scanner

# ── Data paths ────────────────────────────────────────────────────────────────
# These must match the volume mount point — do not change unless remapping.
PARQUET_DATA_PATH=/app/data/parquet
LOG_FILE_PATH=/app/data/notifications.jsonl

# ── CORS ──────────────────────────────────────────────────────────────────────
# In single-container mode the frontend is served from the same origin,
# so wildcard is safe. Restrict this if exposing the API directly.
CORS_ORIGINS=*
